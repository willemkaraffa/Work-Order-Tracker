{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(*)",
      "Edit(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/verify-thrash-guard.js" }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/verify-thrash-guard.js" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/length-check.js"
          }
        ]
      }
    ]
  }
}