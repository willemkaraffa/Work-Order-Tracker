{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PWD}/.claude/scripts/inject-values.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PWD}/.claude/scripts/inject-reminder.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}