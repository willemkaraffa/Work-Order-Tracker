{
  "name": "work-order-tracker",
  "version": "2.7.0",
  "description": "Work Order Tracker – Gamble Plumbing Heating and Air",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "publish-win": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.gambleplumbing.workorders",
    "productName": "Work Order Tracker",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "willemkaraffa",
      "repo": "Work-Order-Tracker",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "scraper.js",
      "index.html",
      "assets/**"
    ],
    "extraFiles": [
      {
        "from": "sync_to_lookup.py",
        "to": "resources/sync_to_lookup.py"
      },
      {
        "from": "preflight_qa.py",
        "to": "resources/preflight_qa.py"
      }
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
